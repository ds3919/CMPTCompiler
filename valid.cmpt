{
  int a
  int b
  int c
  boolean d
  boolean e

  a = 1
  b = 2
  c = 1 + b

  print(a)
  print(b)
  print(c)

  d = (a == b)
  e = (a != b)

  print(d)
  print(e)

  if true {
    print(9)
  }

  if (a != b) {
    print(8)
  }
}$

{
  int i
  int l
  boolean k

  i = 0
  l = 3
  k = true

  while (i != l) {
    print(i)
    i = 1 + i
  }

  k = false

  if (k == true) {
    print(9)
  }

  print(i)
}$

{
  string s
  string t
  boolean m

  s = "hello"
  t = "bye"

  print(s)
  print(t)
  print("done")

  m = true
  print(m)
}$